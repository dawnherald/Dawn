typedef long int HugeInt;
#include<stdlib.h>
int RandInt(HugeInt X, HugeInt Y);
HugeInt
Witness(HugeInt A, HugeInt i, HugeInt N)
{
	HugeInt X, Y;

	if (i == 0)
		return 1;

	X = Witness(A, i / 2, N);
	if (X == 0)
		return 0;

	Y = (X * X) % N;
	if (Y == 1 && X != 1 && X != N - 1)
		return 0;                            //这里是关于定理二的实现如果：X^2 mod N = 1时，X不为1或者N-1，则说明N为非素数

	if (i % 2 != 0)
		Y = (A * Y) % N;       // 判断i为奇数还是偶数，当幂为奇数的时候，要多乘一次A
	return Y;
}
int 
IsPrime(HugeInt N)
{
	return Witness(RandInt(2, N - 2), N - 1, N) == 1;//randint应该就是从（2；n-2）范围里面返回一个随机值判断利用定理一素性
}
